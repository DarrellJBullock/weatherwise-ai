# Base URL used for metadata + Open Graph tags. Update per environment.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: only needed if you swap the mock provider for a live weather API
# (see lib/weather/weatherService.ts). Leave blank to keep using mock data.
WEATHER_API_KEY=

# Optional: map provider selection for a future live map integration.
NEXT_PUBLIC_MAP_PROVIDER=

# Optional: only needed if NEXT_PUBLIC_MAP_PROVIDER=mapbox is used later.
# The built-in WeatherMap component does not require this — it renders a
# custom radar-console map with no external tiles or API keys.
NEXT_PUBLIC_MAPBOX_TOKEN=
